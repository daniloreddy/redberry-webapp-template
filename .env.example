HOST=127.0.0.1
PORT=8000
DEV=false
# Fuso orario per i timestamp mostrati in dashboard (IANA tz name, es. Europe/Rome).
# I dati restano salvati come epoch UTC internamente — TZ regola solo il display.
TZ=UTC

AUTH_SECURE_COOKIE=0
TRUSTED_PROXIES=127.0.0.1

# Token bearer opzionale per endpoint API fuori da /ui (comma-separated). Vuoto = aperto (solo uso locale).
API_TOKENS=

# Rate limit sugli endpoint API (sintassi slowapi, es. "20/minute"). Hot-reloadable
# (letto da ConfigManager a ogni richiesta, non serve restart per cambiarlo).
RATE_LIMIT=20/minute

# Auto-refresh pannelli dashboard — runtime-editable dalla pagina Config (hot-reload).
REFRESH_ENABLED=true
REFRESH_INTERVAL=5

# Solo Docker: sposta lo storage utente di NiceGUI (tema dark/light, ecc.) dentro la
# directory dati bind-montata, altrimenti si azzera ad ogni ricreazione del container.
NICEGUI_STORAGE_PATH=/app/data/.nicegui
